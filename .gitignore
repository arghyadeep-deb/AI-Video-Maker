# Secrets
.env
.env.local

# Media (gitignored data root — specs/03-design/08-data-model.md)
media/

# Backend (Python)
backend/.venv/
backend/**/__pycache__/
backend/.pytest_cache/
*.pyc

# Worker agent (task-20a) - venv, local config (contains the worker token),
# and in-flight task scratch never leave the owner's PC
worker-agent/.venv/
worker-agent/config.toml
worker-agent/**/__pycache__/
worker-agent/.pytest_cache/
worker-agent/bakeoff-results/

# Large model weights (fetched by backend/scripts/setup_models.py, not committed)
backend/vendor/wav2lip/checkpoints/*.pth
backend/vendor/wav2lip/face_detection/detection/sfd/*.pth
backend/vendor/wav2lip/temp/*.avi
backend/vendor/wav2lip/results/
backend/vendor/openvoice/checkpoints_v2/converter/*.pth

# Voice-clone / enrollment artifacts (user likeness data - never committed)
backend/vendor/openvoice/checkpoints_v2/base_speakers/

# Frontend (Next.js)
frontend/node_modules/
frontend/.next/
frontend/next-env.d.ts

# Deployment secrets (task-20) - real values live only on the VM/in CI secrets
deploy/.env
deploy/*.pem
deploy/*.key

# Local Claude Code session state (machine-local, not project data)
.claude/
.gstack/
**/.gstack/

# OS
.DS_Store
Thumbs.db

.vercel
.env*

# PC-hosted dev/preview tunnel (deploy/tunnel/*.cmd are kept as reusable
