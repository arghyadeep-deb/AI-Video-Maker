# Copy to .env at the repo root and fill in your own free keys.
# See README.md for a 5-minute walkthrough of obtaining each one.

GEMINI_API_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Optional - risk R2's text fallback chain (Gemini -> Groq -> OpenRouter).
# Free keys: https://console.groq.com | https://openrouter.ai/settings/keys
# Models are config too (free-tier catalogs churn): GROQ_MODEL, OPENROUTER_MODEL.
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Home GPU worker (task-20a): a single long random string shared between
# this server and worker-agent/config.toml on the owner's PC. Leave unset
# to disable the /api/worker endpoints entirely.
# Generate one:  python -c "import secrets; print(secrets.token_urlsafe(32))"
WORKER_TOKEN=
